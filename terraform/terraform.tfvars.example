# Copy to terraform.tfvars (gitignored) and fill in:
#   cp terraform.tfvars.example terraform.tfvars

aws_region    = "eu-north-1"
instance_type = "t3.micro"
http_port     = 80

# Your SSH public key — Terraform registers it as wine-knot-deploy in AWS
#   cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... your-email@example.com"

# Your public IP only — Cloudflare does NOT proxy SSH
ssh_cidr_blocks = ["203.0.113.10/32"]

# --- Secrets (NEVER commit terraform.tfvars) ---
# Stored in AWS SSM Parameter Store (SecureString) by Terraform.
# The EC2 instance reads them at boot; you retrieve them with:
#   aws ssm get-parameter --region eu-north-1 --name /wine-knot/admin_password --with-decryption --query Parameter.Value --output text

# Token needs: Zone DNS Edit, Zone Settings Edit, Access: Apps and Policies Write, Zero Trust Write
cloudflare_api_token = "your_cloudflare_api_token_here"

# Cloudflare Access — email OTP before /admin.html (who may log in)
admin_allowed_emails = ["admin@example.com"]

# Legacy SSM admin_password (no longer used by the app; CF Access is the admin gate).
# admin_password = "choose-a-strong-password"

cloudflare_zone      = "wineknot.co.il"
cloudflare_subdomain = "@"
cloudflare_proxied   = true
