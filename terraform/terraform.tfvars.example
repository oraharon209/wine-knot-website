# Copy to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

aws_region    = "eu-west-1"   # or il-central-1 (Tel Aviv) if available on your account
instance_type = "t3.small"
http_port     = 80            # match HTTP_PORT in .env (use 80 in production)

# Paste the contents of your public key file:
#   cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... your-email@example.com"

# Restrict SSH to your IP (recommended):
# ssh_cidr_blocks = ["203.0.113.10/32"]
