# Database
MYSQL_ROOT_PASSWORD=change_me_root
DB_USER=wineknot
DB_PASSWORD=change_me_db
DB_NAME=wineknot

# Web
HTTP_PORT=8080

# Images — local for dev, s3 on AWS (Terraform sets these automatically)
# IMAGE_STORAGE=local
# IMAGE_STORAGE=s3
# S3_BUCKET=wine-knot-wine-images-123456789012
# AWS_REGION=eu-north-1
# S3_PUBLIC_BASE_URL=https://wine-knot-wine-images-123456789012.s3.eu-north-1.amazonaws.com

# Docker Hub (for push/pull on server)
# DOCKERHUB_USER=yourusername
# DOCKER_IMAGE_BACKEND=yourusername/wine-knot-backend:latest

# Admin panel (/admin.html) — שנה סיסמה לפני פרודקשן!
ADMIN_PASSWORD=change_me_admin

# Cloudflare DDNS (production only — docker compose --profile production up)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE=wineknot.co.il
CLOUDFLARE_SUBDOMAIN=@
CLOUDFLARE_PROXIED=false

# Contact (shown on website)
CONTACT_PHONE=050-0000000
CONTACT_WHATSAPP=972500000000
CONTACT_EMAIL=info@wineknot.co.il
